        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Những Gì Bạn Đã Thử\n- Khởi động lại ứng dụng: Có/Không\n- Khôi phục tại Runners Store: Có/Không\n- Gỡ cài đặt ứng dụng: Có/Không"
