      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Was hast du probiert\n- Neustart der app: Ja/Nein\n- Läufer Store wiederhergestellt: Ja/Nein\n- App deinstalliert: Ja/Nein"
